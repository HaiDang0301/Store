<div class="mt-4" style="margin-left: 50px;">
  <div class="row">
    <div class="col-sm-6 col-lg-4">
        {{#each products}}
    <div class="card" style="width: 18rem;margin-top: 50px;">
      <a href="/product/{{this.slug}}">
      <img src="{{this.image}}" class="card-img-top" alt="...">
      </a>
      <div class="card-body" style="width: 300px; height: 250px;">
        <a href="/product/{{this.slug}}" style="text-decoration: none;">
        <h5 class="card-title">{{this.name}}</h5></a>
        <p class="card-text">{{this.description}}</p>
        <p class="card-text">Giá: {{this.price}}</p>
        <a href="#" class="btn btn-primary" style="margin-left: 90px;">Mua</a>
      </div>
    </div>
    {{/each}}
  </div>
</div>
</div>
</div>